    // --------------------------------------------right rotation-----------------------------------
             public void rotate(int[] arr, int k) {
          int n = arr.length;
         k = k%n;
          swap(arr,0,n-1); // whoole
          swap(arr,0,k-1); // 1dt k
          swap(arr,k,n-1); // left 


    }
