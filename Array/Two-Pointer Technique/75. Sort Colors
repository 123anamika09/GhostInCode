        // 0 - 0 to low-1  store 
        // 1 - low to mid-1
        // 2 - high+1 to n-1 

        //  mid to high -- ?? here unsorted part store  but when mid == high it means it is sorted & then the gap goes empty 

        //  sorted part increases & unsorted part shirnk
        // nums[mid] = 0 , nums[mid ] =1 , nums[mid] =2 

        //   case 1----nums[mid] = 0 , then swap (nums[low], nums[mid]) low++, mid++ swapping k krn mid always comes 1 so we do mid++
        // case 2----nums[mid] = 1 , then  mid++
        // case 1----nums[mid] = 2 , then swap (nums[high], nums[mid]) high-- here mid pr unsorted eement aayega
        int low = 0;
        int mid = 0;
        int high = nums.length -1 ;
        while(mid<= high){
            if(nums[mid] == 0){
                int temp = nums[mid];
                nums[mid] = nums[low];
                nums[low] =  temp;
                low++;
                mid++; 
            } else if(nums[mid ] == 1){
                mid++;
            }else {
                int temp = nums[high];
                nums[high] = nums[mid];
                nums[mid] = temp;
                high --;
            }
        }


    }
