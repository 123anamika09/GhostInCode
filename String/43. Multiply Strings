class Solution {
    public String multiply(String num1, String num2) {
        // if(num1.length() == 0 || num2.length() == 0) return "" ;
        // long a = Long.parseLong(num1);
        // long b = Long.parseLong(num2);
        // long res = a*b;
        // return String.valueOf(res);
        int n = num1.length();
        int m = num2.length();
         int []res =  new int[m+n];
         if(num1.equals("0") || num2.equals("0")) return "0" ;
         for(int i = n-1;i>=0;i--){
            for(int j = m-1;j>=0;j--){
                int mul = (num1.charAt(i) - '0') * (num2.charAt(j) - '0');
                //  now set position for element where it stores 
                //  0 1 4 5
                //  9 3 1 3
                // *
                //         p1 position
                //       p2 postion for carry
                int p1 = i+j; // carry
                int p2 = i+j+1;// for value

                int sum = mul + res[p2]; //add existing value at this position
                res[p2] = sum%10;
                res[p1] += sum/10; // for carry

            }
         }

        //   conversion
        StringBuilder sb = new StringBuilder();
            // now current res looks like this = [0,4,0,8] but we want"408" so 
            for(int x: res){
                if(sb.length()!=0  || x!=0)
                sb.append(x);
            }
            return sb.toString();

    }
}
