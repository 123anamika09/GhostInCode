class Solution {
    public char findTheDifference(String s, String t) {
        char[] ch =s.toCharArray();
        char[] c = t.toCharArray();
        Arrays.sort(ch);
        Arrays.sort(c);
        int i = 0;int j = 0;
        while(i<ch.length && j<c.length){
            if(ch[i] != c[j]){
                return c[j];
            }
            i++;
            j++;
        }
        return c[c.length-1];
    }
}

