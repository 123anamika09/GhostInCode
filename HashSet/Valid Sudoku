class Solution {
    public boolean isValidSudoku(char[][] board) {


        HashSet<Character> []row = new HashSet[9]; //creating an array of 9 HashSet ,Each index represents one row of Sudoku
        HashSet<Character>[] col = new HashSet[9];
        HashSet<Character>[] eachBox = new HashSet[9];


        for(int i = 0;i<9;i++){
            
                row[i] = new HashSet<>();//creating object for row[i] before this row[i] = [null,null, .....] 
                //after creating object row[i] = [{},{},{}.....{}]
                col[i] = new HashSet<>();
                eachBox[i] = new HashSet<>();
            
        }

        for(int i = 0;i<9;i++){
            for(int j = 0;j<9;j++){
                char c = board[i][j];
                if(c == '.'){
                    continue;
                }
                int boxIdx = (i/3)*3 + j/3;
                // check duplicates
                if(row[i].contains(c) || col[j].contains(c)|| eachBox[boxIdx].contains(c)) return false;
                row[i].add(c);
                col[j].add(c);
                eachBox[boxIdx].add(c);
            }
        }
        return true;
    }
}
